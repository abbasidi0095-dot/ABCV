# abCV env config — copy to .env.local and fill in real values

# Database (docker-compose exposes on 5433 to avoid local pg conflicts)
DATABASE_URL="postgresql://abcv:abcv_dev@localhost:5433/abcv?schema=public"

# Auth.js
NEXTAUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# OpenCode Go LLM (DeepSeek V4 Flash)
OPENCODE_GO_API_KEY=""
OPENCODE_GO_BASE_URL="https://opencode.ai/zen/go/v1"
OPENCODE_GO_MODEL="deepseek-v4-flash"