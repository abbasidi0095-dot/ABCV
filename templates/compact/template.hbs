<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.4; font-size: 9pt; }
  .page { display: flex; min-height: 297mm; width: 210mm; }
  .sidebar {
    width: 30%; background: #1e293b; color: #e2e8f0; padding: 14mm 8mm 10mm;
    display: flex; flex-direction: column; gap: 14px;
  }
  .main { flex: 1; padding: 14mm 10mm 10mm; }
  .photo { width: 90px; height: 120px; object-fit: cover; border-radius: 50%; margin: 0 auto 10px; display: block; border: 3px solid rgba(255,255,255,0.2); }
  .photo-placeholder { width: 90px; height: 120px; border-radius: 50%; margin: 0 auto 10px; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; font-size: 28px; color: rgba(255,255,255,0.6); }
  .sidebar h2 { font-size: 8pt; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 6px; font-weight: 600; }
  .contact-info { font-size: 8.5pt; word-break: break-word; display: flex; flex-direction: column; gap: 4px; }
  .sidebar ul { list-style: none; display: flex; flex-wrap: wrap; gap: 4px; }
  .sidebar li { background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 2px; font-size: 8pt; }
  .main h1 { font-size: 20pt; font-weight: 700; letter-spacing: -0.02em; color: #0f172a; }
  .main .role-line { color: var(--accent); font-size: 10pt; font-weight: 500; margin-top: 1px; }
  .main section { margin-top: 14px; }
  .main h3 { font-size: 9pt; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 6px; border-bottom: 1px solid #e2e8f0; padding-bottom: 3px; }
  .summary { font-size: 9pt; color: #475569; }
  .exp-item { margin-bottom: 10px; }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .exp-title { font-weight: 600; font-size: 9.5pt; }
  .exp-company { color: #64748b; font-size: 9pt; }
  .exp-dates { color: #94a3b8; font-size: 8pt; white-space: nowrap; }
  .bullets { margin-top: 3px; padding-left: 14px; }
  .bullets li { margin-bottom: 2px; }
</style>
</head>
<body>
<div class="page">
  <aside class="sidebar">
    {{#if photoB64}}
      <img class="photo" src="{{photoB64}}" alt="" />
    {{else}}
      <div class="photo-placeholder">{{initials}}</div>
    {{/if}}

    <h2>Contact</h2>
    <div class="contact-info">
      <span>{{email}}</span>
      <span>{{phone}}</span>
    </div>

    <h2>Skills</h2>
    <ul>
      {{#each content.skills}}<li>{{this}}</li>{{/each}}
    </ul>
  </aside>

  <main class="main">
    <h1>{{fullName}}</h1>
    {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}

    <section>
      <h3>Summary</h3>
      <p class="summary">{{content.summary}}</p>
    </section>

    <section>
      <h3>Experience</h3>
      {{#each content.experience}}
        <div class="exp-item">
          <div class="exp-head">
            <div>
              <span class="exp-title">{{title}}</span>
              <span class="exp-company">· {{company}}</span>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="bullets">
            {{#each bullets}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/each}}
    </section>
  </main>
</div>
</body>
</html>
